{
  "name": "winccoa-mcp-server",
  "version": "0.1.3",
  "description": "MCP server for WinCC OA – exposes datapoint operations to LLM agents",
  "main": "dist/index.js",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node18 --format=cjs --outfile=dist/index.js --external:winccoa-manager && cpy .env.example dist --flat",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "dev": "vitest watch",
    "clean": "rimraf dist",
    "start": "node dist/index.js",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "dotenv": "^17.3.1",
    "express": "^4.21.2",
    "winccoa-manager": "file:../../Program Files/Siemens/WinCC_OA/3.21/javascript/winccoa-manager",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/express": "^5.0.2",
    "@types/node": "^22.15.3",
    "@vitest/coverage-v8": "^3.0.0",
    "cpy-cli": "^7.0.0",
    "esbuild": "^0.27.3",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.0.0"
  }
}
