# ── WinCC OA MCP Server Configuration ─────────────────────────────────
#
# Copy this file to `.env` and adjust the values as needed.
# The WinCC OA Node.js Manager does not support command-line arguments,
# so all configuration is done through environment variables.

# Transport mode: "stdio" or "http"
MCP_TRANSPORT=stdio

# Port for the HTTP transport (only used when MCP_TRANSPORT=http)
MCP_HTTP_PORT=3000

# Maximum response size in characters to prevent overwhelming the LLM context
MCP_CHARACTER_LIMIT=25000
